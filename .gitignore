# Dependencies
node_modules

# Build output
dist
dist-ssr
*.local

# Editor
.vscode/*
!.vscode/extensions.json
.idea

# OS
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test
coverage

# Session scratch space (ui-audit screenshots, handoff notes, spec drafts) --
# never publish; the repo is public.
.scratch/

# Mirrored firmware (scripts/sync-firmware.sh output) -- build/deploy-time
# content, not source. See docs/notes/decisions-m1.md decision 4.
public/firmware/*
!public/firmware/.gitkeep

# sync-firmware.sh staging dir; normally removed by its own EXIT trap, but
# ignored defensively in case a run gets killed before the trap fires.
.sync-firmware-staging.*
